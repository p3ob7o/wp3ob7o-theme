{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{ "slug": "bg", "color": "#f8f7f4", "name": "Background" },
				{ "slug": "text", "color": "#1a1a1a", "name": "Text" },
				{ "slug": "text-secondary", "color": "#555555", "name": "Text Secondary" },
				{ "slug": "text-muted", "color": "#999999", "name": "Text Muted" },
				{ "slug": "accent", "color": "#9b4d3a", "name": "Accent" },
				{ "slug": "accent-hover", "color": "#7d3e2e", "name": "Accent Hover" },
				{ "slug": "border", "color": "#e0ddd8", "name": "Border" },
				{ "slug": "surface-raised", "color": "#f0eeea", "name": "Surface Raised" },
				{ "slug": "dark-text-bg", "color": "#111111", "name": "Dark Text Background" },
				{ "slug": "dark-text-color", "color": "#b0ada8", "name": "Dark Text Color" },
				{ "slug": "dark-photo-bg", "color": "#0a0a0a", "name": "Dark Photo Background" },
				{ "slug": "dark-photo-color", "color": "#888888", "name": "Dark Photo Color" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Source Serif 4\", \"Iowan Old Style\", \"Palatino Linetype\", Palatino, Georgia, serif",
					"name": "Source Serif 4",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Source Serif 4",
							"fontWeight": "200 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,200..900&display=swap" ]
						},
						{
							"fontFamily": "Source Serif 4",
							"fontWeight": "200 900",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [ "https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@1,8..60,200..900&display=swap" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "meta", "size": "13px", "name": "Meta" },
				{ "slug": "small", "size": "15px", "name": "Small" },
				{ "slug": "medium", "size": "17px", "name": "Body" },
				{ "slug": "large", "size": "22px", "name": "H2" },
				{ "slug": "x-large", "size": "28px", "name": "H1" },
				{ "slug": "xx-large", "size": "clamp(28px, 4vw, 36px)", "name": "Display" }
			],
			"fluid": false
		},
		"spacing": {
			"units": [ "px", "rem", "%", "vw" ],
			"spacingSizes": [
				{ "slug": "20", "size": "2px", "name": "2XS" },
				{ "slug": "30", "size": "4px", "name": "XS" },
				{ "slug": "40", "size": "8px", "name": "SM" },
				{ "slug": "50", "size": "16px", "name": "MD" },
				{ "slug": "60", "size": "24px", "name": "LG" },
				{ "slug": "70", "size": "32px", "name": "XL" },
				{ "slug": "80", "size": "48px", "name": "2XL" }
			]
		},
		"layout": {
			"contentSize": "640px",
			"wideSize": "960px"
		},
		"custom": {
			"spacing": {
				"paragraph": "12px",
				"headingAbove": "32px",
				"headingBelow": "8px"
			},
			"layout": {
				"photo": "800px",
				"linkInBio": "400px",
				"specimen": "720px"
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--bg)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.45"
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-hover)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "400",
					"lineHeight": "1.25"
				},
				"spacing": {
					"margin": {
						"top": "32px",
						"bottom": "8px"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600"
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "12px"
					}
				}
			},
			"core/image": {
				"spacing": {
					"margin": {
						"top": "24px",
						"bottom": "24px"
					}
				}
			},
			"core/quote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "italic",
					"lineHeight": "1.35"
				},
				"border": {
					"left": {
						"color": "var(--wp--preset--color--border)",
						"width": "2px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "20px"
					},
					"margin": {
						"top": "32px",
						"bottom": "32px"
					}
				}
			}
		}
	},
	"customTemplates": [
		{ "name": "single-photo", "title": "Single Photo", "postTypes": [ "post" ] },
		{ "name": "page-specimen", "title": "Specimen", "postTypes": [ "page" ] },
		{ "name": "front-page-bio", "title": "Link-in-Bio", "postTypes": [ "page" ] }
	],
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
